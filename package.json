{
  "name": "mcp-apple-notes",
  "version": "1.0.2",
  "author": "Conner K Ward",
  "type": "module",
  "main": "index.ts",
  "description": "An MCP server for semantic search and connection-discovery across your own Apple Notes — hybrid search, Swanson-ABC bridges, entity threads, and cited synthesis over everything you've written.",
  "keywords": ["apple-notes", "mcp", "model-context-protocol", "semantic-search", "notes", "knowledge-graph"],
  "license": "MIT",
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node",
    "build:ui": "vite build",
    "postinstall": "bun run build:ui && open 'x-apple.systempreferences:com.apple.preference.security?Privacy_AllFiles' 2>/dev/null; true",
    "start": "bun index.ts",
    "purge-db": "rm -rf ~/.mcp-apple-notes/data ~/.mcp-apple-notes/index_state.json",
    "test": "bun test ./test.ts"
  },
  "exports": {
    ".": "./index.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.8",
    "@huggingface/transformers": "^3.1.2",
    "@lancedb/lancedb": "^0.14.0",
    "@langchain/textsplitters": "^0.1.0",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "run-jxa": "^3.0.0",
    "turndown": "^7.2.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.5",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
